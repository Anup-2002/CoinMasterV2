# OPENAI_API_KEY: Required for OpenAI GPT API calls.
# Configure this in your environment or hosting platform.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# APP_URL: The URL where this application is hosted.
# Configure this with your deployed production or local service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CMC_API_KEY: Optional. CoinMarketCap Pro API Key.
# If not provided, the bot will fetch live crypto prices from a public free API.
CMC_API_KEY="YOUR_CMC_PRO_API_KEY"
